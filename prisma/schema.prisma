generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ItemCategory {
  RAW_MATERIAL
  PACKAGING
  FINISHED_GOOD
}

enum PurchaseOrderStatus {
  OPEN
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum AlertType {
  STOCKOUT_RISK
  EXPIRING_LOT
  REORDER
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Item {
  id                   String                 @id @default(cuid())
  name                 String                 @unique
  category             ItemCategory
  unitOfMeasure        String
  shelfLifeDays        Int?
  defaultSupplierId    String?
  leadTimeDays         Int                    @default(0)
  minimumOrderQuantity Decimal                @default(0) @db.Decimal(12, 3)
  orderMultiple        Decimal                @default(1) @db.Decimal(12, 3)
  costPerUnit          Decimal                @default(0) @db.Decimal(12, 4)
  organicFlag          Boolean                @default(false)
  safetyStock          Decimal                @default(0) @db.Decimal(12, 3)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  defaultSupplier      Supplier?              @relation("DefaultSupplier", fields: [defaultSupplierId], references: [id])
  supplierItems        SupplierItem[]
  bomHeaders           BOM[]
  bomComponents        BOMLine[]
  inventoryLots        InventoryLot[]
  purchaseOrderLines   PurchaseOrderLine[]
  productionPlanLines  ProductionPlanLine[]
  recommendations      Recommendation[]
  alerts               Alert[]
}

model Supplier {
  id                   String       @id @default(cuid())
  name                 String       @unique
  contact              String?
  leadTimeDays         Int          @default(0)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  defaultItems         Item[]       @relation("DefaultSupplier")
  supplierItems        SupplierItem[]
  purchaseOrders       PurchaseOrder[]
}

model SupplierItem {
  id                   String    @id @default(cuid())
  supplierId           String
  itemId               String
  unitCost             Decimal   @default(0) @db.Decimal(12, 4)
  minimumOrderQuantity Decimal   @default(0) @db.Decimal(12, 3)
  createdAt            DateTime  @default(now())
  supplier             Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  item                 Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([supplierId, itemId])
}

model BOM {
  id                 String    @id @default(cuid())
  finishedGoodItemId String    @unique
  batchSize          Decimal   @db.Decimal(12, 3)
  yieldPercent       Decimal   @default(100) @db.Decimal(5, 2)
  targetPrice        Decimal?  @db.Decimal(12, 4)
  fillSizeOz         Decimal?  @db.Decimal(8, 3)
  labelDescription   String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  finishedGoodItem   Item      @relation(fields: [finishedGoodItemId], references: [id], onDelete: Cascade)
  lines              BOMLine[]
}

model BOMLine {
  id                String   @id @default(cuid())
  bomId             String
  componentItemId   String
  quantityRequired  Decimal  @db.Decimal(12, 3)
  createdAt         DateTime @default(now())
  bom               BOM      @relation(fields: [bomId], references: [id], onDelete: Cascade)
  componentItem     Item     @relation(fields: [componentItemId], references: [id], onDelete: Cascade)
}

model InventoryLot {
  id                String   @id @default(cuid())
  itemId            String
  lotCode           String
  receivedDate      DateTime
  expirationDate    DateTime?
  quantityAvailable Decimal  @db.Decimal(12, 3)
  quantityAllocated Decimal  @default(0) @db.Decimal(12, 3)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  item              Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model PurchaseOrder {
  id                  String              @id @default(cuid())
  supplierId          String
  orderDate           DateTime
  expectedReceiptDate DateTime
  status              PurchaseOrderStatus @default(OPEN)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  supplier            Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  lines               PurchaseOrderLine[]
}

model PurchaseOrderLine {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  itemId           String
  quantity         Decimal       @db.Decimal(12, 3)
  unitCost         Decimal       @db.Decimal(12, 4)
  createdAt        DateTime      @default(now())
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  item             Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model ProductionPlan {
  id         String               @id @default(cuid())
  startDate  DateTime
  endDate    DateTime
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  lines      ProductionPlanLine[]
}

model ProductionPlanLine {
  id                  String          @id @default(cuid())
  productionPlanId    String
  finishedGoodItemId  String
  scheduledDate       DateTime?
  quantity            Decimal         @db.Decimal(12, 3)
  createdAt           DateTime        @default(now())
  productionPlan      ProductionPlan  @relation(fields: [productionPlanId], references: [id], onDelete: Cascade)
  finishedGoodItem    Item            @relation(fields: [finishedGoodItemId], references: [id], onDelete: Cascade)
}

model Recommendation {
  id               String   @id @default(cuid())
  itemId           String
  recommendedQty   Decimal  @db.Decimal(12, 3)
  orderByDate      DateTime
  reason           String
  priorityScore    Int
  createdAt        DateTime @default(now())
  item             Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model Alert {
  id         String        @id @default(cuid())
  alertType  AlertType
  severity   AlertSeverity
  itemId     String
  message    String
  createdAt  DateTime      @default(now())
  item       Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
}
